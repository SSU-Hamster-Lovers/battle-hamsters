FROM rust:1-bookworm AS builder

WORKDIR /app

COPY . .

RUN cargo build --release

FROM debian:bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /app/target/release/battle-hamsters-server /usr/local/bin/battle-hamsters-server

ENV API_PORT=8081
EXPOSE 8081

CMD ["battle-hamsters-server"]
